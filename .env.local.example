NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 선택 사항입니다. 있으면 서버 API가 RLS 걱정 없이 analysis_runs 기록을 만들 수 있습니다.
# 절대 NEXT_PUBLIC_을 붙이지 마세요.
SUPABASE_SERVICE_ROLE_KEY=

# true면 Supabase 환경변수가 있어도 브라우저 localStorage로 테스트합니다.
NEXT_PUBLIC_USE_LOCAL_DATA=false

# Supabase Authentication에서 Anonymous sign-ins를 켠 뒤 true로 두면 로그인 UI 없이 MVP 테스트가 가능합니다.
NEXT_PUBLIC_ENABLE_DEV_ANON_AUTH=true

# 실제 AI 연동은 서버에서만 사용합니다. 브라우저에 노출하지 마세요.
OPENAI_API_KEY=

# true로 바꾸면 서버 분석 함수에서 실제 AI 연결 지점을 탑니다.
USE_REAL_AI=false

# PDF 내부 텍스트/OCR이 실패하면 OPENAI_API_KEY가 있을 때 자동으로 비전 이미지 분석을 시도합니다.
# 사용할 모델을 바꾸고 싶으면 아래 값을 수정하세요.
OPENAI_PDF_VISION_MODEL=gpt-5

# PDF OCR용 Tesseract 설정입니다. 한국어 일촬표는 kor+eng를 권장합니다.
TESSERACT_PATH=
TESSERACT_LANG=kor+eng
TESSDATA_PREFIX=
